{
  "name": "seamly2dwebapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "e2e": "playwright test",
    "format": "prettier --write .",
    "build:static": "NEXT_PUBLIC_BASE_PATH=/seamly2dwebapp NEXT_PUBLIC_STATIC_MODE=1 next build && node scripts/make-404.js && touch out/.nojekyll",
    "deploy": "gh-pages -d out -b gh-pages"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "expr-eval": "^2.0.2",
    "fast-xml-parser": "^4.3.2",
    "immer": "^10.0.3",
    "nanoid": "^5.1.5",
    "next": "14.2.31",
    "react": "^18",
    "react-dom": "^18",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.31",
    "gh-pages": "^6.1.1",
    "postcss": "^8",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^1.0.4"
  }
}
